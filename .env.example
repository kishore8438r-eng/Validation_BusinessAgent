# RAG Validation System - Environment Variables

# API Keys for AI Services
COHERE_API_KEY=your_cohere_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Optional: OpenAI API Key (if you want to use OpenAI instead of Google)
# OPENAI_API_KEY=your_openai_api_key_here

# Application Configuration
APP_ENV=development
LOG_LEVEL=INFO

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Optional: Database Configuration (for future use)
# DATABASE_URL=postgresql://user:password@localhost:5432/rag_validation

# Optional: Redis Configuration (for caching)
# REDIS_URL=redis://localhost:6379

# Optional: External Service URLs
# COHERE_BASE_URL=https://api.cohere.ai
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com

# Security
SECRET_KEY=your_secret_key_here
API_KEY_EXPIRY_HOURS=24

# File Processing
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=json,txt,csv

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10